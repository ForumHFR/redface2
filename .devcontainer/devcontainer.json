{
  "name": "redface2-android",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
  "mounts": [
    "source=${localWorkspaceFolder}/.gradle-user/devcontainer-gradle,target=/home/ubuntu/.gradle,type=bind",
    "source=${localWorkspaceFolder}/.gradle-user/devcontainer-android,target=/home/ubuntu/.android,type=bind"
  ],
  "remoteUser": "ubuntu",
  "updateRemoteUserUID": true,
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      },
      "extensions": [
        "vscjava.vscode-gradle",
        "redhat.vscode-yaml"
      }
    }
  }
}
